# Copy this to digit_classifier/.env and fill in your values.
# digit_classifier/.env is gitignored - never commit it.

WANDB_API_KEY=your_key_here
WANDB_ENTITY=your_entity_here
WANDB_PROJECT=jersey-number-pipeline-aggregation
SLURM_ACCOUNT=your_slurm_account_here

# Path to the SoccerNet root directory (used as --data default)
DIGIT_DATA_DIR=/home/${USER}/jersey-number-pipeline/data/SoccerNet
DIGIT_GT=/scratch/${USER}/jersey-agg-data/train_gt.json
DIGIT_TEST_GT=/scratch/${USER}/jersey-agg-data/test_gt.json
DIGIT_OUTPUT_DIR=/scratch/${USER}/jersey-digit-checkpoints
